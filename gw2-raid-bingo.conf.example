# gw2-raid-bingo runtime configuration (systemd EnvironmentFile format).
# On the host this is installed to /etc/gw2-raid-bingo.conf, root-owned 0600.
# Copy to a real file and fill in the secrets; never commit the filled-in copy.

# --- Discord (required for the bot) ---
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
# Optional: register slash commands instantly to one guild while developing.
# Leave empty in production to register globally.
DISCORD_DEV_GUILD_ID=

# --- Discord OAuth (required for the website) ---
DISCORD_CLIENT_SECRET=

# --- Data ---
DB_PATH=/opt/gw2-raid-bingo/data/bingo.db
# Path to the private seed file; only applied to SEED_GUILD_ID. Leave empty on
# servers other than the home guild.
SEED_FILE=/opt/gw2-raid-bingo/seed/entries.json
SEED_GUILD_ID=1098188107708371015

# --- Web ---
HTTP_ADDR=127.0.0.1:8771
# BASE_URL is the ORIGIN only (scheme + host, no path). The public landing is
# served by nginx at / on this origin; the game app is mounted under BASE_PATH.
BASE_URL=https://gw2-raid-bingo.duckdns.org
# Path prefix the game is served under (unset or / = the origin root). The Discord
# OAuth redirect URI must match BASE_URL + BASE_PATH + /auth/callback exactly. In
# production this is /play (the landing is served by nginx at /); set it as part of
# the nginx cutover so the app and nginx agree on the prefix at the same moment.
BASE_PATH=/play
